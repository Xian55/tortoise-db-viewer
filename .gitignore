node_modules/
dist/
__pycache__/
*.pyc
# Prerendered OG link-preview stubs (regenerated by scripts/build-og.mjs in CI)
og-stubs/
# Built data (regenerated by scripts/build-db.mjs in CI)
public/data/*.sqlite
public/data/*.sqlite-journal
public/data/version.json
# Dev-dataset build (server 1181dev branch; built by deploy-dev.yml / DATA_SUBDIR=data-dev)
public/data-dev/*.sqlite
public/data-dev/*.sqlite-journal
public/data-dev/version.json
# Embed tooltip JSON (regenerated by scripts/build-tooltips.mjs; deploy writes dist/tt)
public/tt/
*.log
.DS_Store
# Local notes / drafts — never committed
notes/
# Local env files (VITE_* vars etc.) — never commit; secrets live in CI secrets
.env
.env.*
!.env.example
