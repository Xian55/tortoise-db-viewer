{
  "name": "tortoise-wow-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fast static item database (octowow-style) for Tortoise-WoW, hosted on GitHub Pages",
  "scripts": {
    "build:db": "node scripts/build-db.mjs",
    "build:json": "node scripts/build-json.mjs",
    "build:data": "node scripts/build-db.mjs && node scripts/build-json.mjs",
    "build:icons": "python scripts/extract-icons.py",
    "build:atlas": "python scripts/build-atlas.py",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0",
    "vite": "^6.0.7"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "leaflet": "^1.9.4",
    "leaflet-pixi-overlay": "^1.9.5",
    "pixi.js": "^7"
  }
}
